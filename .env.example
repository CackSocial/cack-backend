# Server
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=socialconnect
DB_SSLMODE=disable

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY_HOURS=72

# Upload
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE_MB=10

# Base URL (used for constructing full URLs for uploaded files)
BASE_URL=http://localhost:8080

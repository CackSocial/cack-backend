{
	"info": {
		"name": "SocialConnect API",
		"description": "Complete API collection for the SocialConnect social networking platform.\n\n**Setup:**\n1. Run \"Register\" or \"Login\" first — the token is auto-saved to the collection variable `token`.\n2. All protected endpoints use `{{token}}` automatically via Bearer auth.\n3. Dynamic variables like `{{postId}}`, `{{commentId}}`, `{{user2Token}}` are set by test scripts.\n\n**Test Flow:**\n1. Auth → Register User 1 → Register User 2\n2. Posts → Create Post → Get Post → Get User Posts\n3. Follows → Follow User → Get Followers → Timeline\n4. Likes → Like Post → Get Likes\n5. Comments → Create Comment → Get Comments → Delete Comment\n6. Messages → Send Message → Get Conversation → Get Conversations\n7. Tags → Trending Tags → Posts by Tag\n8. Cleanup → Delete Post → Unfollow",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
		{ "key": "token", "value": "" },
		{ "key": "user2Token", "value": "" },
		{ "key": "userId", "value": "" },
		{ "key": "user2Id", "value": "" },
		{ "key": "username", "value": "johndoe" },
		{ "key": "user2Username", "value": "janedoe" },
		{ "key": "postId", "value": "" },
		{ "key": "commentId", "value": "" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{token}}" }]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register User 1",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.success) {",
									"    pm.collectionVariables.set('token', res.data.token);",
									"    pm.collectionVariables.set('userId', res.data.user.id);",
									"    pm.test('Registration successful', () => pm.response.to.have.status(201));",
									"    pm.test('Token received', () => pm.expect(res.data.token).to.be.a('string'));",
									"    pm.test('Username matches', () => pm.expect(res.data.user.username).to.eql(pm.collectionVariables.get('username')));",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": "{{baseUrl}}/auth/register",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{username}}\",\n    \"password\": \"password123\",\n    \"display_name\": \"John Doe\"\n}"
						}
					}
				},
				{
					"name": "Register User 2",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.success) {",
									"    pm.collectionVariables.set('user2Token', res.data.token);",
									"    pm.collectionVariables.set('user2Id', res.data.user.id);",
									"    pm.test('Registration successful', () => pm.response.to.have.status(201));",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": "{{baseUrl}}/auth/register",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{user2Username}}\",\n    \"password\": \"password123\",\n    \"display_name\": \"Jane Doe\"\n}"
						}
					}
				},
				{
					"name": "Login User 1",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.success) {",
									"    pm.collectionVariables.set('token', res.data.token);",
									"    pm.test('Login successful', () => pm.response.to.have.status(200));",
									"    pm.test('Token received', () => pm.expect(res.data.token).to.be.a('string'));",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": "{{baseUrl}}/auth/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{username}}\",\n    \"password\": \"password123\"\n}"
						}
					}
				},
				{
					"name": "Login User 2",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.success) {",
									"    pm.collectionVariables.set('user2Token', res.data.token);",
									"    pm.test('Login successful', () => pm.response.to.have.status(200));",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": "{{baseUrl}}/auth/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{user2Username}}\",\n    \"password\": \"password123\"\n}"
						}
					}
				},
				{
					"name": "Login - Invalid Credentials",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Returns 401', () => pm.response.to.have.status(401));",
									"pm.test('Error message', () => pm.expect(pm.response.json().success).to.be.false);"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": "{{baseUrl}}/auth/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{username}}\",\n    \"password\": \"wrongpassword\"\n}"
						}
					}
				},
				{
					"name": "Register - Duplicate Username",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Returns 409 Conflict', () => pm.response.to.have.status(409));"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": "{{baseUrl}}/auth/register",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{username}}\",\n    \"password\": \"password123\",\n    \"display_name\": \"Duplicate\"\n}"
						}
					}
				}
			]
		},
